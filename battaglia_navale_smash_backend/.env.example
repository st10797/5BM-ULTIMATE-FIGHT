# ============================================================
# Variabili d'ambiente per il backend (Render)
# ============================================================

# Porta del server — Render la imposta automaticamente
# Nome variabile Render: PORT
PORT=3000

# Ambiente di esecuzione
# Nome variabile Render: NODE_ENV
NODE_ENV=production

# URL del frontend Vercel — per la configurazione CORS
# Nome variabile Render: FRONTEND_URL
FRONTEND_URL=https://your-app.vercel.app
